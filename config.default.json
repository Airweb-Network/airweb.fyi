{
  "ssh": {
    "host": "0.0.0.0",
    "port": 2222,
    "hostKeyPath": "./keys/host_rsa"
  },
  "http": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "limits": {
    "reservedPorts": [22, 2222, 8080, 8090, 8091],
    "tcpPortRange": [10000, 20000],
    "reservedSubdomains": ["www", "api", "admin", "dashboard", "app", "docs", "doc", "forum", "blog", "status", "mail", "smtp", "imap", "pop", "ftp", "ssh"],
    "allowCustomSubdomains": false
  },
  "credits": {
    "signupBonus": 100,
    "uptimePerMinute": 1,
    "bandwidthChargePerMb": 0.01,
    "usdPerCredit": 0.01,
    "defaultLeasePricePerMinute": 2,
    "handleBaseCost": 50,
    "handleMinLength": 3,
    "handleMaxLength": 32
  },
  "sessions": {
    "cookieName": "airweb_sid",
    "ttlDays": 30
  },
  "data": {
    "dir": "./data",
    "dbFile": "airweb.sqlite"
  },
  "internalDoc": {
    "enabled": true,
    "port": 8090,
    "subdomain": "doc",
    "title": "Airweb Docs"
  },
  "internalForum": {
    "enabled": true,
    "port": 8091,
    "subdomain": "forum",
    "title": "Airweb Forum"
  }
}

# AirWeb environment overrides. Copy to `.env` and edit.
# Values in the real shell environment take precedence over this file.

# Public domain users hit in the browser. Subdomains map to tunnels
# (e.g. mysub.<AIRWEB_PUBLIC_DOMAIN>).
#   - Local dev:   lvh.me:8080   (lvh.me resolves *.lvh.me to 127.0.0.1)
#   - Production:  airweb.fyi
AIRWEB_PUBLIC_DOMAIN=lvh.me:8080

# http for local dev, https in production (behind TLS terminator)
AIRWEB_PUBLIC_SCHEME=http

# AirWeb environment overrides. Copy to `.env` and edit.
# Values in the real shell environment take precedence over this file.

# Public base URL users hit in the browser. Used as the base for all link
# generation; subdomains map to tunnels (e.g. https://mysub.<host>).
# Include the scheme (http:// or https://).
#   - Local dev:   http://lvh.me        (lvh.me resolves *.lvh.me to 127.0.0.1)
#   - Production:  https://airweb.fyi
AIRWEB_PUBLIC_DOMAIN=http://lvh.me
